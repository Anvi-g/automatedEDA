# agents.py
from google.adk.agents import LlmAgent
from google.adk.code_executors import BuiltInCodeExecutor
from google.adk.tools import AgentTool

# ---------------------------------------------------------
# Agent 2: Code Executor (The Worker)
# ---------------------------------------------------------
# This agent has the "Skill" to run code.
executor_agent = LlmAgent(
    name="code_executor",
    model="gemini-2.0-flash", # Optimized for coding
    instruction="""
    You are a Python Data Engineer.
    
    YOUR JOB:
    1. Receive instructions from the Orchestrator.
    2. Write and Execute Python code.
    3. IMPORTANT: The environment may reset. ALWAYS:
       - Load 'housing_data.csv' at the start.
       - Perform the fix.
       - Save the result back to 'housing_data.csv'.
       - Print df.info() or df.head() to show the Orchestrator the result.
    """,
    # FIX: The executor capability goes here, NOT in tools
    code_executor=BuiltInCodeExecutor() 
)

# ---------------------------------------------------------
# Agent 1: Orchestrator (The Planner)
# ---------------------------------------------------------
# This agent has the "Skill" to delegate to the executor.
orchestrator_agent = LlmAgent(
    name="orchestrator",
    model="gemini-2.0-flash", # Stronger reasoning
    instruction="""
    You are a Senior Data Scientist managing a data cleaning pipeline.
    
    PRIMARY GOAL:
    1. Clean 'housing_data.csv' (Handle NaNs, Outliers, Types).
    2. Save the final clean file as 'cleaned_data.csv'.
    
    LOOP:
    1. ANALYZE: Read the output provided by the code_executor.
    2. PLAN: Determine the next cleaning step.
    3. DELEGATE: Call the 'code_executor' agent to perform the step.
    
    CRITICAL:
    - You cannot run code yourself. You MUST use the 'code_executor'.
    - Keep looping until the data is clean.
    - When satisfied, ask executor to save 'cleaned_data.csv'.
    - Output "DATA CLEANING COMPLETE" only when that file is saved.
    """,
 
    tools=[AgentTool(agent=executor_agent)]
)




# version 2 - 3 Agent Form

# agents.py
import pandas as pd
import numpy as np
from google.adk.agents import LlmAgent
from google.adk.tools import AgentTool, FunctionTool
from tools import run_local_python

# ---------------------------------------------------------
# 4. THE DETERMINISTIC CLEANER (Not an Agent, just Logic)
# ---------------------------------------------------------

def standard_cleaning_tool(filepath: str) -> str:
    """
    Performs standard data cleaning WITHOUT using an LLM.
    1. Drops duplicates.
    2. Fills numeric NaNs with Median.
    3. Fills categorical NaNs with Mode.
    4. Saves to 'cleaned_data.csv'.
    """
    try:
        # Re-import numpy pandas inside if running in isolated environments,
        df = pd.read_csv(filepath)
        report = []
        
        # 1. Duplicates
        initial_len = len(df)
        df.drop_duplicates(inplace=True)
        if len(df) < initial_len:
            report.append(f"Dropped {initial_len - len(df)} duplicates.")

        # 2. NaNs
        for col in df.columns:
            if df[col].isnull().sum() > 0:
                if np.issubdtype(df[col].dtype, np.number):
                    val = df[col].median()
                    df[col].fillna(val, inplace=True)
                    report.append(f"Filled NaNs in '{col}' with Median ({val}).")
                else:
                    val = df[col].mode()[0]
                    df[col].fillna(val, inplace=True)
                    report.append(f"Filled NaNs in '{col}' with Mode ('{val}').")

        # Save
        df.to_csv("cleaned_data.csv", index=False)
        report.append("Saved result to 'cleaned_data.csv'.")
        
        return "\n".join(report) if report else "Data was already clean. Saved to 'cleaned_data.csv'."
    except Exception as e:
        return f"Error in standard cleaning: {e}"


# ---------------------------------------------------------
# Agent 3: The Critic (The Auditor)
# ---------------------------------------------------------
critic_agent = LlmAgent(
    name="critic_agent",
    model="gemini-1.5-flash", 
    instruction="""
    You are a Data Quality Auditor.
    
    TASK:
    Generate a comprehensive "Linear Regression Readiness Report" for 'cleaned_data.csv'.
    
    STEPS:
    1. Load 'cleaned_data.csv' via 'run_local_python'.
    2. Check EVERYTHING in one pass: Missing Values, Object Types, Outliers, Low Correlation.
    3. Generate the report.
    
    REPORT FORMAT:
    --- AUDIT REPORT ---
    ISSUES:
    1. [Issue Description] (e.g., "Column 'Age' has 5 NaNs")
    2. [Issue Description] (e.g., "Column 'City' is type Object")
    ...
    --------------------
    VERDICT: [READY / NOT READY]
    """,
    tools=[FunctionTool(run_local_python)]
)

# ---------------------------------------------------------
# Agent 2: Code Executor (The Batch Worker)
# ---------------------------------------------------------
executor_agent = LlmAgent(
    name="code_executor",
    model="gemini-2.0-flash-lite", 
    instruction="""
    You are a Python Data Engineer.
    
    TASK:
    1. Receive a BATCH of specific cleaning instructions from the Orchestrator.
    2. Write a SINGLE Python script that performs ALL instructions sequentially.
    3. Execute using 'run_local_python'.
    
    SCRIPT REQUIREMENTS:
    - Load 'cleaned_data.csv' (or raw file if first run).
    - Apply Fix 1, Fix 2, Fix 3... in order.
    - Save to 'cleaned_data.csv'.
    - Print df.info() to verify.
    """,
    tools=[FunctionTool(run_local_python)] 
)

# ---------------------------------------------------------
# Agent 1: Orchestrator (The Tech Lead)
# ---------------------------------------------------------
orchestrator_agent = LlmAgent(
    name="orchestrator",
    model="gemini-2.0-flash-lite", # Efficient Manager
    instruction="""
    You are a Technical Lead managing a Hybrid AI Data Pipeline.
    
    GOAL: Produce a clean dataset efficiently.
    
    WORKFLOW:
    
    STEP 1: DISCOVER & FAST CLEAN (Deterministic Phase)
    - First, look for the CSV file in the current directory.
    - Once found, IMMEDIATE ACTION: Call the 'standard_cleaning_tool' with that filename.
    - This tool will automatically handle NaNs, duplicates, and simple encoding.
    
    STEP 2: THE AUDIT LOOP (Reasoning Phase)
    - Call 'critic_agent' to audit the result ('cleaned_data.csv').
    - READ the Report.
    
    STEP 3: DECISION & COMPLEX FIXES
    - IF "VERDICT: READY" -> Output "DATA CLEANING COMPLETE".
    
    - IF "VERDICT: NOT READY" -> 
      1. Review the issues. These are complex issues the standard tool missed.
      2. Translate them into specific Pandas instructions.
      3. Send ONE batch message to 'code_executor' to apply these custom fixes.
      4. Loop back to STEP 2.
    
    CRITICAL:
    - ALWAYS run 'standard_cleaning_tool' before asking the Code Executor to do anything. It is free and fast.
    - Use 'code_executor' ONLY for complex fixes requested by the Critic.
    """,
    tools=[
        FunctionTool(standard_cleaning_tool), # The "Free" Tool
        AgentTool(agent=executor_agent),      # The "AI Worker"
        AgentTool(agent=critic_agent)         # The "AI Critic"
    ]
)



version 3 - 2 agent critic (orchestrator+coder)
import pandas as pd
import numpy as np
from google.adk.agents import LlmAgent
from google.adk.tools import AgentTool, FunctionTool
from tools import run_local_python, strict_statistical_check

# ---------------------------------------------------------
# 1. TOOL: Standard Deterministic Cleaner (GENERIC)
# ---------------------------------------------------------
def standard_cleaning_tool(filepath: str) -> str:
    """Standard cleaning: Drop duplicates, Median fill, Mode fill, Z-score Outliers."""
    try:
        import pandas as pd
        import numpy as np

        df = pd.read_csv(filepath)
        report = []
        
        # 1. Duplicates
        init_len = len(df)
        df = df.drop_duplicates()
        if len(df) < init_len: 
            report.append(f"Dropped {init_len-len(df)} duplicates.")

        # 2. NaNs
        for col in df.columns:
            if df[col].isnull().sum() > 0:
                if np.issubdtype(df[col].dtype, np.number):
                    median_val = df[col].median()
                    df[col] = df[col].fillna(median_val)
                    report.append(f"Filled NaNs in {col} (Median: {median_val}).")
                else:
                    mode_s = df[col].mode()
                    if not mode_s.empty:
                        mode_val = mode_s[0]
                        df[col] = df[col].fillna(mode_val)
                        report.append(f"Filled NaNs in {col} (Mode: {mode_val}).")

        # Drop Constant Columns (Zero Variance)
        for col in df.columns:
            if df[col].nunique() <= 1:
                df.drop(columns=[col], inplace=True)
                report.append(f"Dropped constant column '{col}' (Single unique value).")


        # 3. Outliers (Z-score > 3)
        numeric_cols = df.select_dtypes(include=[np.number]).columns
        for col in numeric_cols:
            if df[col].std() > 0: 
                z_scores = np.abs((df[col] - df[col].mean()) / df[col].std())
                outliers = z_scores > 3
                num_outliers = outliers.sum()
                if num_outliers > 0:
                    df = df[~outliers]
                    report.append(f"Removed {num_outliers} outliers from '{col}' (Z-score > 3).")
        
        df.to_csv("cleaned_data.csv", index=False)
        report.append("Saved to 'cleaned_data.csv'.")
        return "\n".join(report)
    except Exception as e: 
        return f"Error: {e}"

# ---------------------------------------------------------
# 2. AGENT: The Strict Critic (Reasoning Engine)
# ---------------------------------------------------------
critic_agent = LlmAgent(
    name="critic_agent",
    model="gemini-2.0-flash", # Valid Model ID
    instruction="""
 
    You are a Data Quality Auditor & Feature Strategist.
    
     
    TASK: Generate a "Regression Readiness & Engineering Report" for 'cleaned_data.csv'.
    
    WORKFLOW:
    1. Load data via 'run_local_python'.
    2. RUN 'strict_statistical_check' tool (for stats).
    3. PERFORM SEMANTIC CHECKS (Your reasoning):
       - Look at column names. Do columns like 'Price', 'Area', 'Age', 'Distance', 'Count' have negative values? (Impossible).
       - Interactions: Do you see 'Length' & 'Width' (Suggest Area)? 'Start' & 'End' (Suggest Duration)?
       - Do columns imply a ratio? (e.g. 5000 sqft with 1 bedroom is suspicious).
       - Cardinality: Do categorical columns have > 50 unique values? (Suggest Target Encoding).

    REPORT FORMAT:
    --- AUDIT REPORT ---
    ISSUES:
    1. [Logic Issue] (e.g. "Column 'Square_Feet' has negatives")
    2. [Stat Issue] (e.g. "Dummy Trap in Neighborhood")
    3. [Engineering Opp] (e.g. "Create 'Area' from Length*Width")
    ...
    VERDICT: [READY / NOT READY]
    """,
    tools=[
        FunctionTool(run_local_python),
        FunctionTool(strict_statistical_check)
    ]
)

# ---------------------------------------------------------
# 3. AGENT: The Orchestrator (Manager + Coder)
# ---------------------------------------------------------
orchestrator_agent = LlmAgent(
    name="orchestrator",
    model="gemini-2.5-flash", 
    instruction="""
    You are a Senior Data Scientist.
    
    GOAL: Produce a dataset optimized for Linear Regression.
    
    WORKFLOW:
    1. FAST CLEAN: Run 'standard_cleaning_tool'.
    2. AUDIT LOOP: Run 'critic_agent'. Read Report.
    3. ACTION: Fix issues using the "Smart Strategies".
    4. FINALIZE: When "VERDICT: READY" (or if you are stuck looping), write 'cleaning_report.md' and stop.
    
    SMART STRATEGIES:
    
    1. LOGIC & STATS:
       - Negative Values: Drop rows. `df = df[df['col'] >= 0]`
       - Boolean: `df[col] = df[col].astype(int)`
       
    2. MULTICOLLINEARITY (High VIF > 10):
       - Compare 'CorrWithTarget' in the report.
       - DROP the feature with LOWER correlation.
    
    3. TRANSFORMATION (Skewness Handling):
       - **Right Skew (> 1):** Use Log Transform.
         Code: `df['col'] = np.log1p(df['col'])`
       - **Left Skew (< -1):** Use Square Transform (pushes mass right).
         Code: `df['col'] = df['col']**2`
       - **Persistence:** If you have already transformed a column once, DO NOT transform it again. Accept the remaining skew as "Best Effort".
    
    4. SCALING:
       - Range Diff: `scaler.fit_transform(df[['col']])`

    5. ENCODING:
       - < 50 unique: One-Hot (`dtype=int`).
       - > 50 unique: Target Encoding.

    CRITICAL BATCHING RULES:
    - Aggregate ALL fixes into ONE Python script execution.
    - **Anti-Looping:** If the Critic complains about the SAME issue (e.g. "Skew in Age") for the second time, IGNORE IT. Do not re-apply the same fix.
    - Always load 'cleaned_data.csv', modify it, and save it back.
    - On finish: Write 'cleaning_report.md' explaining your decisions.
    """,
    tools=[
        FunctionTool(standard_cleaning_tool), 
        FunctionTool(run_local_python),       
        AgentTool(agent=critic_agent)         
    ]
)