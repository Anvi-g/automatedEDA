# agents.py
from google.adk.agents import LlmAgent
from google.adk.code_executors import BuiltInCodeExecutor
from google.adk.tools import AgentTool

# ---------------------------------------------------------
# Agent 2: Code Executor (The Worker)
# ---------------------------------------------------------
# This agent has the "Skill" to run code.
executor_agent = LlmAgent(
    name="code_executor",
    model="gemini-2.0-flash", # Optimized for coding
    instruction="""
    You are a Python Data Engineer.
    
    YOUR JOB:
    1. Receive instructions from the Orchestrator.
    2. Write and Execute Python code.
    3. IMPORTANT: The environment may reset. ALWAYS:
       - Load 'housing_data.csv' at the start.
       - Perform the fix.
       - Save the result back to 'housing_data.csv'.
       - Print df.info() or df.head() to show the Orchestrator the result.
    """,
    # FIX: The executor capability goes here, NOT in tools
    code_executor=BuiltInCodeExecutor() 
)

# ---------------------------------------------------------
# Agent 1: Orchestrator (The Planner)
# ---------------------------------------------------------
# This agent has the "Skill" to delegate to the executor.
orchestrator_agent = LlmAgent(
    name="orchestrator",
    model="gemini-2.0-flash", # Stronger reasoning
    instruction="""
    You are a Senior Data Scientist managing a data cleaning pipeline.
    
    PRIMARY GOAL:
    1. Clean 'housing_data.csv' (Handle NaNs, Outliers, Types).
    2. Save the final clean file as 'cleaned_data.csv'.
    
    LOOP:
    1. ANALYZE: Read the output provided by the code_executor.
    2. PLAN: Determine the next cleaning step.
    3. DELEGATE: Call the 'code_executor' agent to perform the step.
    
    CRITICAL:
    - You cannot run code yourself. You MUST use the 'code_executor'.
    - Keep looping until the data is clean.
    - When satisfied, ask executor to save 'cleaned_data.csv'.
    - Output "DATA CLEANING COMPLETE" only when that file is saved.
    """,
 
    tools=[AgentTool(agent=executor_agent)]
)